/target
**/*.rs.bk
.DS_Store

# vagus runtime state never lives in the repo (it lives in ~/.local/share/vagus and
# ~/Library/Caches/vagus). Guard against accidental local copies:
/.fastembed_cache
*.sqlite
*.sqlite-*

# Claude Code (ADR 0018 / G21): the global ~/.gitignore ignores .claude/ wholesale. Override here so
# the committed project settings is the ONLY tracked .claude file — re-include the dir, ignore its
# contents (per-agent worktrees, machine-local overrides), then un-ignore settings.json.
!.claude/
.claude/*
!.claude/settings.json
